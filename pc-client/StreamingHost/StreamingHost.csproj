<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>StreamingHost</RootNamespace>
    <AssemblyName>StreamingHost</AssemblyName>
    <PlatformTarget>x64</PlatformTarget>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Web SDK defaults to launching IIS Express on debug; we don't want that -->
    <UseAppHost>true</UseAppHost>
  </PropertyGroup>

  <ItemGroup>
    <!-- WebRTC (pure .NET) -->
    <PackageReference Include="SIPSorcery" Version="6.2.4" />
    <PackageReference Include="SIPSorceryMedia.FFmpeg" Version="6.2.0" />
    <!-- Per-window capture via Windows.Graphics.Capture -->
    <PackageReference Include="Microsoft.Windows.CsWinRT" Version="2.1.5" />
    <!-- Direct3D 11 / DXGI -->
    <PackageReference Include="Vortice.Direct3D11" Version="3.6.2" />
    <PackageReference Include="Vortice.DXGI" Version="3.6.2" />
  </ItemGroup>

  <ItemGroup>
    <!-- Windows Runtime APIs (Windows.Graphics.Capture) -->
    <CsWinRTIncludes Include="Windows.Graphics.Capture" />
    <CsWinRTIncludes Include="Windows.Graphics.DirectX" />
    <CsWinRTIncludes Include="Windows.Graphics.DirectX.Direct3D11" />
  </ItemGroup>

</Project>
